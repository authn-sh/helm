{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "authn.sh chart values",
  "type": "object",
  "additionalProperties": true,
  "required": ["image", "env", "secrets"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] },
        "pullSecrets": { "type": "array" }
      }
    },
    "env": {
      "type": "object",
      "properties": {
        "AUTHN_ROUTING_MODE": { "type": "string", "enum": ["subdomain", "path"] }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "existingSecret": { "type": "string" },
        "values": { "type": "object" }
      }
    },
    "replicaCount": {
      "type": "object",
      "properties": {
        "web": { "type": "integer", "minimum": 1 },
        "worker": { "type": "integer", "minimum": 0 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    }
  }
}
